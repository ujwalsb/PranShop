# ═══════════════════════════════════════════════
# Prandhara ERP - Environment Configuration
# ═══════════════════════════════════════════════
# Copy this file to backend/.env and fill in your values:
#   cp .env.example backend/.env
#
# For production deployment, set NODE_ENV=production
# and update CLIENT_URL to your actual domain.

# ---- Server ----
PORT=5000
NODE_ENV=development

# ---- MongoDB (Required) ----
# Local: mongodb://localhost:27017/newshop20123
# Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/newshop20123

# ---- JWT Authentication (Required) ----
JWT_SECRET=change_this_to_a_strong_random_string_in_production
JWT_EXPIRES_IN=7d

# ---- Email (SMTP) - Required for password reset ----
# For Gmail: use an App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# ---- Frontend URL - Used for email links & CORS ----
CLIENT_URL=http://localhost:5173

# ---- Razorpay Payment Gateway (Optional) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
